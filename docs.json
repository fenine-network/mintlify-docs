{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Fenine Network Documentation",
  "colors": {
    "primary": "#e17100",
    "light": "#e17100",
    "dark": "#e17100"
  },
  "favicon": "./logo/logo-light.svg",
  "font": {
    "headings": {
      "family": "Space Grotesk"
    },
    "body": {
      "family": "Space Grotesk"
    },
    "code": {
      "family": "Fira Code"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "index"
            ]
          },
          {
            "group": "Why Build on Fenine",
            "pages": [
              "guides/why-build",
              "guides/technical-advantages",
              "guides/unique-features"
            ]
          },
          {
            "group": "Community",
            "pages": [
              "essentials/official-links"
            ]
          }
        ]
      },
      {
        "tab": "Architecture",
        "groups": [
          {
            "group": "Core Concepts",
            "pages": [
              "architecture/overview",
              "architecture/consensus",
              "architecture/execution",
              "architecture/fpos"
            ]
          }
        ]
      },
      {
        "tab": "Node Operators",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "node-operators/overview"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/quick-reference"
            ]
          },
          {
            "group": "RPC Endpoints",
            "pages": [
              "api-reference/rpc/overview",
              {
                "group": "fenine_* Methods",
                "pages": [
                  "api-reference/rpc/fenine-namespace",
                  "api-reference/rpc/fenine/get-snapshot",
                  "api-reference/rpc/fenine/get-signers",
                  "api-reference/rpc/fenine/get-system-contract-abi",
                  "api-reference/rpc/fenine/get-contract-constants"
                ]
              },
              {
                "group": "eth_* Methods",
                "pages": [
                  "api-reference/rpc/eth-namespace",
                  "api-reference/rpc/eth/get-active-validators",
                  "api-reference/rpc/eth/get-validator-info",
                  "api-reference/rpc/eth/get-validator-stakers",
                  "api-reference/rpc/eth/get-delegator-info",
                  "api-reference/rpc/eth/get-estimated-delegator-reward",
                  "api-reference/rpc/eth/total-network-stake",
                  "api-reference/rpc/eth/get-current-epoch",
                  "api-reference/rpc/eth/get-proximity-config"
                ]
              }
            ]
          },
          {
            "group": "Smart Contracts",
            "pages": [
              "api-reference/contracts/fenine-system",
              "api-reference/contracts/nft-passport"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "dApps",
          "href": "https://stake.fene.app",
          "icon": "first-order-alt"
        },
        {
          "anchor": "Bridge",
          "href": "https://bridge.fene.app",
          "icon": "bridge"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/logo.svg",
    "dark": "/logo/logo-light.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@fene.network"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Stake Now",
      "href": "https://stake.fene.app"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/feninesnetwork",
      "github": "https://github.com/fenines-network",
      "discord": "https://discord.gg/fenines"
    }
  }
